# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini AI
VITE_GEMINI_API_KEY=your-gemini-api-key

# Pexels (4교시 바이럴카드 무료 이미지)
# https://www.pexels.com/api/ 에서 무료 발급 (200 req/hr)
VITE_PEXELS_API_KEY=your-pexels-api-key

# ─── 소셜 로그인 (Supabase Dashboard에서 설정) ───
# 아래 값들은 Supabase Dashboard > Authentication > Providers 에서 설정합니다.
# 코드에서 직접 사용하지 않지만, 설정 시 필요한 값을 기록합니다.
#
# [카카오 (Kakao)]
# 1. https://developers.kakao.com 에서 애플리케이션 생성
# 2. REST API 키를 Supabase Dashboard의 Kakao Client ID에 입력
# 3. Kakao 개발자 콘솔에서 Redirect URI 설정:
#    https://your-project.supabase.co/auth/v1/callback
# 4. 동의항목에서 이메일(필수) 활성화
#
# KAKAO_CLIENT_ID=your-kakao-rest-api-key
# KAKAO_CLIENT_SECRET=your-kakao-client-secret
#
# [구글 (Google)]
# 1. https://console.cloud.google.com 에서 OAuth 2.0 클라이언트 생성
# 2. Client ID/Secret을 Supabase Dashboard의 Google Provider에 입력
# 3. 승인된 리디렉션 URI 설정:
#    https://your-project.supabase.co/auth/v1/callback
#
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
